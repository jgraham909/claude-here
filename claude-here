#!/usr/bin/env bash
# claude-here — launch Claude Code in a sandboxed container.
#
# This is a convenience wrapper around `ai-here` that defaults to the Claude harness.
# All arguments are forwarded to `ai-here`.
#
# Usage:
#   claude-here               — filtered mode (traffic through ai_filtering_proxy)
#   claude-here --unfiltered  — direct internet access, no proxy
#
# See `ai-here --help` for additional options and environment variables.

SCRIPT_DIR="$(dirname "$(realpath "${BASH_SOURCE[0]}")")"
exec "$SCRIPT_DIR/ai-here" --harness claude "$@"
