#!/usr/bin/env bash
# research-here — launch Claude Code in a container with the current directory
# mounted, with direct internet access (no filtering proxy).
#
# Use this for research tasks where the ai_filtering_proxy domain allowlist
# is too restrictive. The container has unrestricted outbound internet access —
# use in less sensitive environments and be mindful of what data leaves the
# container.
#
# Install: copy or symlink this script to a directory on your PATH, e.g.:
#   ln -s /path/to/repo/research-here /usr/local/bin/research-here
#
# Runtime overrides (set in environment before calling):
#   RESEARCH_NETWORK  — Docker network name (default: bridge)

# Consider adding.
# httpie — friendlier HTTP client than curl for API exploration
# ripgrep — faster content search across downloaded repos/docs
# pandoc — convert HTML/markdown/PDF docs
# lynx or w3m — terminal web browser for quick page inspection
# wget is already present (used in the Dockerfile itself)


set -euo pipefail

PROJECT="claude-code"
CLAUDE_CONFIG_DIR="/home/node/claude-config"
HOST_CLAUDE_CONFIG_DIR="${HOME}/.docker-claude"
RESEARCH_NETWORK="${RESEARCH_NETWORK:-bridge}"

CURRENT_DIR_NAME=$(basename "$PWD")

# NOTE: The image has proxy vars baked in as ENV pointing to ai_filtering_proxy.
# We must explicitly clear them so tools (curl, npm, git, etc.) use direct
# connections rather than trying to reach a proxy that won't be reachable on
# this network.
exec docker run -u 1000:1000 --rm -it \
  --network "$RESEARCH_NETWORK" \
  -e HTTP_PROXY="" \
  -e HTTPS_PROXY="" \
  -e http_proxy="" \
  -e https_proxy="" \
  -e NO_PROXY="" \
  -e no_proxy="" \
  -e "CLAUDE_CONFIG_DIR=$CLAUDE_CONFIG_DIR" \
  -v "$HOST_CLAUDE_CONFIG_DIR:$CLAUDE_CONFIG_DIR" \
  -v "$PWD:/$CURRENT_DIR_NAME" \
  -w "/$CURRENT_DIR_NAME" \
  "$PROJECT" bash -c '/usr/local/bin/motd.sh && exec claude'
