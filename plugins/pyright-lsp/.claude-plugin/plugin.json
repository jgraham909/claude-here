{
  "name": "pyright-lsp",
  "version": "1.0.0",
  "description": "Python language server for Claude Code (pyright)",
  "lspServers": {
    "pyright": {
      "command": "pyright-langserver",
      "args": ["--stdio"],
      "extensionToLanguage": {
        ".py": "python",
        ".pyi": "python"
      }
    }
  }
}
