#!/usr/bin/env bash
# claude-here — launch Claude Code in a sandboxed container with the current
# directory mounted, mirroring `make claude-here`.
#
# Install: copy or symlink this script to a directory on your PATH, e.g.:
#   ln -s /path/to/repo/claude-here /usr/local/bin/claude-here
#
# Modes:
#   claude-here               — filtered mode: traffic routed through ai_filtering_proxy
#   claude-here --unfiltered  — direct internet access, no proxy or domain restrictions
#
# Runtime overrides (set in environment before calling):
#   AI_PROXY_NETWORK  — Docker network name (default: ai_proxy_network_internal)
#   PROXY_URL         — HTTP proxy URL     (default: http://ai_filtering_proxy:3128)
#   OPEN_NETWORK      — Docker network for --unfiltered mode (default: bridge)

set -euo pipefail

PROJECT="claude-code"
CLAUDE_CONFIG_DIR="/home/node/claude-config"
HOST_CLAUDE_CONFIG_DIR="${HOME}/.docker-claude"
AI_PROXY_NETWORK="${AI_PROXY_NETWORK:-ai_proxy_network_internal}"
PROXY_URL="${PROXY_URL:-http://ai_filtering_proxy:3128}"
OPEN_NETWORK="${OPEN_NETWORK:-bridge}"

UNFILTERED=0
for arg in "$@"; do
  if [ "$arg" = "--unfiltered" ]; then
    UNFILTERED=1
  fi
done

CURRENT_DIR_NAME=$(basename "$PWD")

# Build --plugin-dir args from ~/.docker-claude/local-plugins/ subdirectories,
# mapped to their container paths. Works for any plugins placed there, not just
# those synced from this repo via `make sync-plugins`.
PLUGIN_ARGS=""
if [ -d "${HOST_CLAUDE_CONFIG_DIR}/local-plugins" ]; then
  for plugin_dir in "${HOST_CLAUDE_CONFIG_DIR}/local-plugins"/*/; do
    [ -d "$plugin_dir" ] || continue
    PLUGIN_ARGS="${PLUGIN_ARGS} --plugin-dir ${CLAUDE_CONFIG_DIR}/local-plugins/$(basename "$plugin_dir")"
  done
fi

if [ "$UNFILTERED" = "1" ]; then
  exec docker run -u 1000:1000 --rm -it \
    --network "$OPEN_NETWORK" \
    -e HTTP_PROXY="" \
    -e HTTPS_PROXY="" \
    -e http_proxy="" \
    -e https_proxy="" \
    -e NO_PROXY="" \
    -e no_proxy="" \
    -e UNFILTERED=1 \
    -e "CLAUDE_CONFIG_DIR=$CLAUDE_CONFIG_DIR" \
    -v "$HOST_CLAUDE_CONFIG_DIR:$CLAUDE_CONFIG_DIR" \
    -v "$PWD:/$CURRENT_DIR_NAME" \
    -w "/$CURRENT_DIR_NAME" \
    "$PROJECT" bash -c "/usr/local/bin/motd.sh && exec claude${PLUGIN_ARGS}"
fi

if ! docker network inspect "$AI_PROXY_NETWORK" >/dev/null 2>&1; then
  echo "ERROR: Docker network '$AI_PROXY_NETWORK' not found. Is the ai_filtering_proxy container running?" >&2
  exit 1
fi

exec docker run -u 1000:1000 --rm -it \
  --network "$AI_PROXY_NETWORK" \
  -e HTTP_PROXY="$PROXY_URL" \
  -e HTTPS_PROXY="$PROXY_URL" \
  -e http_proxy="$PROXY_URL" \
  -e https_proxy="$PROXY_URL" \
  -e NO_PROXY=localhost,127.0.0.1 \
  -e no_proxy=localhost,127.0.0.1 \
  -e "CLAUDE_CONFIG_DIR=$CLAUDE_CONFIG_DIR" \
  -v "$HOST_CLAUDE_CONFIG_DIR:$CLAUDE_CONFIG_DIR" \
  -v "$PWD:/$CURRENT_DIR_NAME" \
  -w "/$CURRENT_DIR_NAME" \
  "$PROJECT" bash -c "/usr/local/bin/motd.sh && exec claude${PLUGIN_ARGS}"
